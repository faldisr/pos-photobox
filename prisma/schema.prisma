// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== USER MANAGEMENT ====================

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  username      String    @unique
  emailVerified DateTime?
  password      String
  image         String?
  role          UserRole  @default(CASHIER)
  branchId      String?
  branch        Branch?   @relation(fields: [branchId], references: [id])
  activeSessionToken  String?   @unique
  sessionTokenVersion Int       @default(0)

  transactions  Transaction[]
  shifts        Shift[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([branchId])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  CASHIER
}

// ==================== BRANCH MANAGEMENT ====================

model Branch {
  id              String    @id @default(cuid())
  name            String
  code            String    @unique
  address         String?   @db.Text
  phone           String?
  email           String?
  city            String?
  province        String?
  postalCode      String?
  isActive        Boolean   @default(true)
  
  // Operational
  operationalHours Json?    // {monday: {open: "09:00", close: "21:00"}, ...}
  
  // Relations
  users           User[]
  transactions    Transaction[]
  shifts          Shift[]
  inventories     Inventory[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("branches")
}

// ==================== PRODUCT MANAGEMENT ====================

model Package {
  id              String    @id @default(cuid())
  name            String
  code            String    @unique
  description     String?   @db.Text
  basePrice       Decimal   @db.Decimal(10, 2)
  photoCount      Int
  isActive        Boolean   @default(true)
  imageUrl        String?
  
  // Specifications
  specifications  Json?
  
  // Relations
  transactionItems TransactionItem[]
  branchPricing    BranchPricing[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("packages")
}

model Template {
  id              String    @id @default(cuid())
  name            String
  code            String    @unique
  category        String
  thumbnailUrl    String?
  description     String?   @db.Text
  isActive        Boolean   @default(true)
  isPopular       Boolean   @default(false)
  
  // Relations
  transactionItems TransactionItem[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("templates")
}

model AddOn {
  id              String    @id @default(cuid())
  name            String
  code            String    @unique
  type            AddOnType
  price           Decimal   @db.Decimal(10, 2)
  description     String?   @db.Text
  isActive        Boolean   @default(true)
  imageUrl        String?
  
  // Relations
  transactionItems TransactionItem[]
  branchPricing    BranchPricing[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("add_ons")
}

enum AddOnType {
  EXTRA_PRINT
  FRAME
  DIGITAL_FILE
  PROPS
  OTHER
}

model BranchPricing {
  id          String   @id @default(cuid())
  branchId    String
  packageId   String?
  addOnId     String?
  price       Decimal  @db.Decimal(10, 2)
  
  package     Package? @relation(fields: [packageId], references: [id])
  addOn       AddOn?   @relation(fields: [addOnId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([branchId, packageId])
  @@unique([branchId, addOnId])
  @@index([branchId])
  @@index([packageId])
  @@index([addOnId])
  @@map("branch_pricing")
}

// ==================== CUSTOMER MANAGEMENT ====================

model Customer {
  id              String    @id @default(cuid())
  name            String?
  email           String?
  phone           String?   @unique
  dateOfBirth     DateTime?
  address         String?   @db.Text
  notes           String?   @db.Text
  
  // Loyalty
  loyaltyPoints   Int       @default(0)
  totalVisits     Int       @default(0)
  totalSpent      Decimal   @default(0) @db.Decimal(10, 2)
  lastVisit       DateTime?
  
  // Relations
  transactions    Transaction[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([phone])
  @@index([email])
  @@map("customers")
}

// ==================== TRANSACTION MANAGEMENT ====================

model Transaction {
  id                String    @id @default(cuid())
  transactionNo     String    @unique
  queueNumber       String?
  branchId          String
  branch            Branch    @relation(fields: [branchId], references: [id])
  cashierId         String
  cashier           User      @relation(fields: [cashierId], references: [id])
  customerId        String?
  customer          Customer? @relation(fields: [customerId], references: [id])
  shiftId           String?
  shift             Shift?    @relation(fields: [shiftId], references: [id])
  
  // Transaction Details
  subtotal          Decimal   @db.Decimal(10, 2)
  discount          Decimal   @default(0) @db.Decimal(10, 2)
  tax               Decimal   @default(0) @db.Decimal(10, 2)
  total             Decimal   @db.Decimal(10, 2)
  
  // Payment
  paymentMethod     PaymentMethod
  paymentStatus     PaymentStatus @default(PENDING)
  paidAmount        Decimal   @db.Decimal(10, 2)
  changeAmount      Decimal   @default(0) @db.Decimal(10, 2)
  
  // Status
  status            TransactionStatus @default(PENDING)

  // Print
  isPrinted         Boolean   @default(false)

  // Promo
  promoCode         String?
  promoDiscount     Decimal   @default(0) @db.Decimal(10, 2)
  
  // Notes
  notes             String?   @db.Text
  cancelReason      String?   @db.Text
  cancelledBy       String?
  cancelledAt       DateTime?

  refundReason      String?   @db.Text
  refundedAt        DateTime?
  
  // Relations
  items             TransactionItem[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([branchId])
  @@index([cashierId])
  @@index([customerId])
  @@index([shiftId])
  @@index([transactionNo])
  @@index([createdAt])
  @@map("transactions")
}

enum PaymentMethod {
  CASH
  DEBIT_CARD
  CREDIT_CARD
  QRIS
  TRANSFER
  E_WALLET
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}

model TransactionItem {
  id              String      @id @default(cuid())
  transactionId   String
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  
  packageId       String?
  package         Package?    @relation(fields: [packageId], references: [id])
  
  templateId      String?
  template        Template?   @relation(fields: [templateId], references: [id])
  
  addOnId         String?
  addOn           AddOn?      @relation(fields: [addOnId], references: [id])
  
  itemName        String
  itemType        String
  quantity        Int         @default(1)
  price           Decimal     @db.Decimal(10, 2)
  subtotal        Decimal     @db.Decimal(10, 2)
  notes           String?     @db.Text
  
  createdAt       DateTime    @default(now())

  @@index([transactionId])
  @@index([packageId])
  @@index([templateId])
  @@index([addOnId])
  @@map("transaction_items")
}

// ==================== SHIFT MANAGEMENT ====================

model Shift {
  id              String    @id @default(cuid())
  shiftNo         String    @unique
  branchId        String
  branch          Branch    @relation(fields: [branchId], references: [id]) 
  cashierId       String
  cashier         User      @relation(fields: [cashierId], references: [id])
  
  // Shift Details
  startTime       DateTime
  endTime         DateTime?
  
  // Cash Management
  openingBalance  Decimal   @db.Decimal(10, 2)
  closingBalance  Decimal?  @db.Decimal(10, 2)
  expectedBalance Decimal?  @db.Decimal(10, 2)
  difference      Decimal?  @db.Decimal(10, 2)
  
  // Summary
  totalTransactions Int     @default(0)
  totalSales      Decimal   @default(0) @db.Decimal(10, 2)
  
  // Payment Breakdown
  cashSales       Decimal   @default(0) @db.Decimal(10, 2)
  cardSales       Decimal   @default(0) @db.Decimal(10, 2)
  qrisSales       Decimal   @default(0) @db.Decimal(10, 2)
  otherSales      Decimal   @default(0) @db.Decimal(10, 2)
  
  notes           String?   @db.Text
  
  // Relations
  transactions    Transaction[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([cashierId])
  @@index([startTime])
  @@map("shifts")
  @@index([branchId])
}

// ==================== INVENTORY MANAGEMENT ====================

model InventoryItem {
  id              String    @id @default(cuid())
  name            String
  code            String    @unique
  category        InventoryCategory
  unit            String
  minStock        Int       @default(0)
  isActive        Boolean   @default(true)
  
  // Costing
  unitCost        Decimal?  @db.Decimal(10, 2)
  
  // Relations
  inventories     Inventory[]
  logs            InventoryLog[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("inventory_items")
}

enum InventoryCategory {
  PAPER
  INK
  FRAME
  PROPS
  OTHER
}

model Inventory {
  id              String        @id @default(cuid())
  branchId        String
  branch          Branch        @relation(fields: [branchId], references: [id])
  itemId          String
  item            InventoryItem @relation(fields: [itemId], references: [id])
  
  quantity        Int
  lastRestockDate DateTime?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([branchId, itemId])
  @@index([branchId])
  @@index([itemId])
  @@map("inventories")
}

model InventoryLog {
  id             String   @id @default(cuid())
  itemId         String
  item           InventoryItem @relation(fields: [itemId], references: [id])

  transactionId  String?

  type           InventoryLogType
  quantity       Int
  quantityBefore Int
  quantityAfter  Int
  note           String?   @db.Text
  createdBy      String

  createdAt      DateTime  @default(now())

  @@index([itemId])
  @@index([transactionId])
  @@index([createdAt])
  @@map("inventory_logs")
}

enum InventoryLogType {
  RESTOCK
  SALE
  ADJUSTMENT
  RETURN
}

// ==================== PROMO MANAGEMENT ====================

model Promo {
  id              String    @id @default(cuid())
  code            String    @unique
  name            String
  description     String?   @db.Text
  type            PromoType
  value           Decimal   @db.Decimal(10, 2)
  
  // Validity
  isActive        Boolean   @default(true)
  
  // Rules
  minPurchase     Decimal?  @db.Decimal(10, 2)
  maxDiscount     Decimal?  @db.Decimal(10, 2)
  usageLimit      Int?
  usageCount      Int       @default(0)
  
  // Applicable
  applicableBranches Json?
  applicablePackages Json?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("promos")
}

enum PromoType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_ITEM
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  entity      String
  entityId    String
  changes     Json?
  ipAddress   String?
  userAgent   String?  @db.Text
  
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
